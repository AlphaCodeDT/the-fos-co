# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Payload
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public site URL (used for SEO, sitemap, RSS, media URLs)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3-compatible storage (Supabase Storage, Cloudflare R2, AWS S3, etc.)
# Leave S3_BUCKET empty to use local disk storage in development.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true

# Seed script (optional — defaults shown)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Platform Admin
