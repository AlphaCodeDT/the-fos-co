# Database (Supabase Postgres)
# Runtime (Vercel/serverless): use the TRANSACTION pooler on port 6543.
# Migrations only (`npm run payload migrate`): use the DIRECT connection on port 5432.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Optional Postgres pool tuning for serverless (defaults shown)
# DATABASE_POOL_MAX=5
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_CONNECTION_TIMEOUT_MS=10000

# Supabase client (browser direct uploads + signed URL minting on server)
NEXT_PUBLIC_SUPABASE_URL=https://cfptjzzjljqfnslfcbcq.supabase.co
# Use either legacy anon JWT or modern publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payload
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public site URL (used for SEO, sitemap, RSS, media URLs)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3-compatible storage (Supabase Storage, Cloudflare R2, AWS S3, etc.)
# Leave S3_BUCKET empty to use local disk storage in development.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true

# Seed script (optional — defaults shown)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Platform Admin

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM=hello@yourdomain.com
# Opt-in: requires verified sending domain in Resend. Keep false in Vercel until domain is verified.
REQUIRE_EMAIL_VERIFICATION=false
# EDITOR_NOTIFICATION_EMAIL=   # optional fallback; default = query all editor users
# TURNSTILE_SITE_KEY=         # deferred — seam only
# TURNSTILE_SECRET_KEY=
